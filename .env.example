# LeanSporty web — environment reference. Copy to .env.local and fill in.
# NEVER prefix a secret with NEXT_PUBLIC_ (that ships it to the browser).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only. Used by the Stripe webhook and lib/instructor-roles.ts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Stream ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_CODE=
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Cloudflare Images delivery hash — required by lib/cloudflare-images.ts image
# transformations (getImageUrl/getThumbnailUrl). Server-only.
CLOUDFLARE_ACCOUNT_HASH=
# Signing key for secure playback (SECURE_PLAYBACK_SPEC §1a). Server only.
# Generate: POST /accounts/$CLOUDFLARE_ACCOUNT_ID/stream/keys → result.id, result.pem (base64).
CLOUDFLARE_STREAM_KEY_ID=
CLOUDFLARE_STREAM_KEY_PEM=

# --- Stripe (commerce) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Enable Stripe Tax (automatic_tax) once the VAT mechanism is settled (OD-1).
STRIPE_AUTOMATIC_TAX=false

# TEMPORARY soft-launch only: when no Stream signing key is set, serve PUBLIC
# (unsigned) playback URLs so the entitled-playback flow works on unsecured
# videos. The entitlement gate still applies, but content is NOT locked at the
# CDN. Remove before any paid launch (configure the signing key instead).
ALLOW_UNSIGNED_PLAYBACK=false

# --- Email (Resend — transactional + abandoned-checkout recovery, E3.4) ---
# API key from our Resend account (this project's own key). Server only.
RESEND_API_KEY=
# Sender on a Resend-verified domain (SPF/DKIM). Founder persona on the isolated
# sending subdomain — need NOT be a real mailbox (replies go to EMAIL_REPLY_TO).
EMAIL_FROM=Anna at Lean Sporty <anna@mail.leansporty.com>
# Real, monitored inbox that replies route to.
EMAIL_REPLY_TO=team@leansporty.com

# --- App / ops ---
# Canonical public origin for links in emails (no trailing slash). Falls back to
# https://leansporty.com. NOT a secret, but kept here for completeness.
NEXT_PUBLIC_SITE_URL=https://leansporty.com
INSTRUCTOR_ACCESS_TOKEN=
# Also signs one-click email unsubscribe tokens (lib/email-token.ts).
CRON_SECRET=
